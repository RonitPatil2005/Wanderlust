<style>
  .btn-search {
    background-color: #fe424d;
    color: #fff;
    border-radius: 25px;
    padding: 0 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    white-space: nowrap;

  }

  .btn-search:hover {
    background-color: #fe424d;
    color: #fff;
  }

  .search-input {
    width: 100%;
    border-radius: 25px;
    padding: 0.5rem 2.8rem 0.5rem 1.2rem;
    font-size: 1rem;
  }

  .search-wrapper {
    position: relative;
    width: 260px;
  }

  .clear-search {
    position: absolute;
    right: 0px;
    top: 50%;
    transform: translateY(-50%);
    width: 22px;
    height: 22px;
    display: none;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    color: #555;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .clear-search:hover {
    color: #111
  }

  .search-input {
    padding-right: 4rem;
  }

  input[type="search"]::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }
  @media (min-width: 768px) {
    .navbar-nav {
      flex-direction: row;
    }

    .search-wrapper {
      width: 260px;
    }
  }

  @media (max-width: 767px) {
    .search-wrapper{
      width: 100%;
      margin-bottom: 0.5rem;
    }

    .btn-search {
      width: 100%;
      margin-bottom: 0.5rem;
    }
  }
</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup"
      aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
      </div>
    <div class="navbar-nav ms-auto">
      <form class="d-flex align-items-center" role="search" action="/listings" method="GET">
          <div class="search-wrapper">
            <input class="form-control search-input" type="search" name="q" id="searchInput"
              placeholder="Search by country or location" value="<%= typeof q !== 'undefined' ? q : '' %>" />
            <span id="clearSearch" class="clear-search"><b>✕</b></span>
          </div>

          <button class="btn btn-search ms-2" type="submit">
            <i class="fa-solid fa-magnifying-glass"></i> Search
          </button>
        </form>
      </div>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/listings/new">Add New Listing</a>
        <% if(typeof currUser === "undefined" || !currUser) { %>
          <a class="nav-link" aria-current="page" href="/signup"><b>Sign up</b></a>
          <a class="nav-link" href="/login"><b>Log in</b></a>
          <% } %>
            <% if(currUser) {%>
              <a class="nav-link" href="/logout"><b>Log out</b></a>
              <% } %>
      </div>
    </div>
  </div>
</nav>




<script>
  const searchInput = document.getElementById("searchInput");
  const clearBtn = document.getElementById("clearSearch");

  if (searchInput.value.trim()) {
    clearBtn.style.display = "block";
  }

  searchInput.addEventListener("input", () => {
    clearBtn.style.display = searchInput.value ? "block" : "none";
  });

  clearBtn.addEventListener("click", () => {
    searchInput.value = "";
    window.location.href = "/listings";
  });
</script>

